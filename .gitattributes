# Normalize all text files to LF in the repository.
# Git checks out with your platform's native line endings, but stores LF,
# so the repo stays consistent across Windows/macOS/Linux and CI.
* text=auto eol=lf

# Explicit text files (line endings normalized to LF)
*.js     text eol=lf
*.cjs    text eol=lf
*.mjs    text eol=lf
*.json   text eol=lf
*.njk    text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.svg    text eol=lf
*.txt    text eol=lf

# Files that must keep CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf

# --- Git LFS: common media files ---
# Stored as LFS objects (keeps the repo small). The deploy workflow checks
# out LFS files (lfs: true) so the built site has the real bytes, not pointers.
# Images
*.png    filter=lfs diff=lfs merge=lfs -text
*.jpg    filter=lfs diff=lfs merge=lfs -text
*.jpeg   filter=lfs diff=lfs merge=lfs -text
*.gif    filter=lfs diff=lfs merge=lfs -text
*.webp   filter=lfs diff=lfs merge=lfs -text
*.avif   filter=lfs diff=lfs merge=lfs -text
*.tif    filter=lfs diff=lfs merge=lfs -text
*.tiff   filter=lfs diff=lfs merge=lfs -text
*.psd    filter=lfs diff=lfs merge=lfs -text
# Video
*.mp4    filter=lfs diff=lfs merge=lfs -text
*.webm   filter=lfs diff=lfs merge=lfs -text
*.mov    filter=lfs diff=lfs merge=lfs -text
*.m4v    filter=lfs diff=lfs merge=lfs -text
# Audio
*.mp3    filter=lfs diff=lfs merge=lfs -text
*.wav    filter=lfs diff=lfs merge=lfs -text
*.m4a    filter=lfs diff=lfs merge=lfs -text
*.ogg    filter=lfs diff=lfs merge=lfs -text
*.flac   filter=lfs diff=lfs merge=lfs -text

# Small binaries kept in regular Git (favicons, vectors, fonts are tiny)
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.otf    binary
*.eot    binary
*.pdf    binary
*.zip    binary
# Note: *.svg is text (vector XML) and is normalized above, not binary.

# Keep generated lockfile out of diffs but still tracked
package-lock.json -diff linguist-generated

# Don't count vendored/build output in language stats
_site/** linguist-generated
